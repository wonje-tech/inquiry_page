# Firebase Console → 프로젝트 설정 → 웹 앱 SDK
# 이 파일을 .env 로 복사한 뒤 값을 채우고 `npm run build:config` 를 실행하세요.
# .env 는 git 에 올리지 마세요.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=dept-consulting.firebaseapp.com
FIREBASE_PROJECT_ID=dept-consulting
FIREBASE_STORAGE_BUCKET=dept-consulting.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=596987696005
FIREBASE_APP_ID=1:596987696005:web:512af2d2606707f862eaec
