{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json","**/.*","**/node_modules/**","scripts/**","functions/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": { "source": "functions" }
}
